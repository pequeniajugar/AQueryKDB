<q>
constMonthly:{(count x)#`monthly};
</q>

WITH
  Target(Id, TradeDate, ClosePrice) AS (
    SELECT Id, TradeDate, ClosePrice
    FROM price
    WHERE Id IN stock10
      AND TradeDate >= startYear10
      AND TradeDate <= startYear10 + 365 * 10
  )

  monthly(Id, bucket, name, low, high, mean) AS (
    SELECT Id,
           timeBucket,
           constMonthly(Id),
           min(ClosePrice),
           max(ClosePrice),
           avg(ClosePrice)
    FROM Target
    GROUP BY Id, getMonth(TradeDate) AS timeBucket
  )

SELECT Id, bucket, name, low, high, mean
FROM monthly
ASSUMING ASC Id, ASC bucket
