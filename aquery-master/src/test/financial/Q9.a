<q>
q9StartDate:{maxTradeDateMinus3Years};
q9StartYear:{getYear maxTradeDateMinus3Years};
q9SplitIds:{exec distinct Id from split where Id in Russell2000, getYear[SplitDate] >= getYear maxTradeDateMinus3Years};
</q>

WITH

  nosplit_avgpx(Id, year, avg_px) AS (
    SELECT Id, year, avg(ClosePrice)
    FROM price
    WHERE Id IN Russell2000
      AND TradeDate >= q9StartDate()
      AND Id NOT IN q9SplitIds()
    GROUP BY Id, getYear(TradeDate)
      AS year
  )

  divdata(Id, year, total_divs) AS (
    SELECT Id, year, sum(DivAmt)
    FROM dividend
    WHERE Id IN Russell2000
      AND getYear(AnnounceDate) >= q9StartYear()
      AND Id NOT IN q9SplitIds()
    GROUP BY Id, getYear(AnnounceDate)
      AS year
  )

SELECT
  Id,
  year,
  float(avg_px) AS avg_px,
  float(total_divs) AS total_divs,
  float(total_divs / avg_px) AS yield
FROM nosplit_avgpx INNER JOIN divdata USING (Id, year)
