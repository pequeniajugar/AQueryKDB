<q>
constYearly:{(count x)#`yearly};
</q>

WITH
  Target(Id, TradeDate, ClosePrice) AS (
    SELECT Id, TradeDate, ClosePrice
    FROM price
    WHERE Id IN stock10
      AND TradeDate >= startYear10
      AND TradeDate <= startYear10 + 365 * 10
  )

  yearly(Id, bucket, name, low, high, mean) AS (
    SELECT Id,
           timeBucket,
           constYearly(Id),
           min(ClosePrice),
           max(ClosePrice),
           avg(ClosePrice)
    FROM Target
    GROUP BY Id, getYear(TradeDate) AS timeBucket
  )

SELECT Id, bucket, name, low, high, mean
FROM yearly
ASSUMING ASC Id, ASC bucket
