<q>
constWeekly:{(count x)#`weekly};
</q>

WITH
  Target(Id, TradeDate, ClosePrice) AS (
    SELECT Id, TradeDate, ClosePrice
    FROM price
    WHERE Id IN stock10
      AND TradeDate >= startYear10
      AND TradeDate <= startYear10 + 365 * 10
  )

  weekly(Id, bucket, name, low, high, mean) AS (
    SELECT Id,
           timeBucket,
           constWeekly(Id),
           min(ClosePrice),
           max(ClosePrice),
           avg(ClosePrice)
    FROM Target
    GROUP BY Id, getWeek(TradeDate) AS timeBucket
  )

SELECT Id, bucket, name, low, high, mean
FROM weekly
ASSUMING ASC Id, ASC bucket
