CREATE TABLE orders(id INT, qty INT)
CREATE TABLE count_log(cnt INT)

CREATE TRIGGER trg_count_after_insert
AFTER INSERT ON orders
REFERENCING NEW TABLE AS inserted
DO INSERT INTO count_log
   SELECT COUNT(qty) AS cnt
   FROM inserted

INSERT INTO orders VALUES(1, 10)
INSERT INTO orders VALUES(2, 20)

<q>
show orders;
show count_log;
</q>
