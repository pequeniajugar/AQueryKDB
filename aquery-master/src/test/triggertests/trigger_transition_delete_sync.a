CREATE TABLE table1(id INT, qty INT, note STRING)
CREATE TABLE table2(id INT, qty INT, note STRING)

INSERT INTO table1 VALUES(1, 10, "src_old")
INSERT INTO table1 VALUES(2, 20, "src2")

INSERT INTO table2 VALUES(1, 0, "dest")
INSERT INTO table2 VALUES(2, 0, "dest2")

CREATE TRIGGER trg_sync_table2_delete
AFTER DELETE ON table1
REFERENCING OLD TABLE AS deleted
DO UPDATE table2
   SET qty = deleted.qty, note = deleted.note
   WHERE table2.id = deleted.id

DELETE FROM table1
WHERE id = 1

<q>
show table1;
show table2;
</q>
