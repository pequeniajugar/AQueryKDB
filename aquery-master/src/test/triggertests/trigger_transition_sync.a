CREATE TABLE table1(id INT, qty INT, note STRING)
CREATE TABLE table2(id INT, qty INT, note STRING)

INSERT INTO table1 VALUES(1, 10, "src")
INSERT INTO table1 VALUES(2, 20, "src2")

INSERT INTO table2 VALUES(1, 0, "dest")
INSERT INTO table2 VALUES(2, 0, "dest2")

CREATE TRIGGER trg_sync_table2
AFTER UPDATE ON table1
REFERENCING NEW TABLE AS inserted
DO UPDATE table2
   SET qty = inserted.qty, note = inserted.note
   WHERE table2.id = inserted.id

UPDATE table1
SET qty = 42
WHERE id = 1

<q>
show table1;
show table2;
</q>
