CREATE TABLE table1(id INT, qty INT, note STRING)
CREATE TABLE audit(id INT, qty INT, note STRING)

INSERT INTO table1 VALUES(1, 10, "src_old")
INSERT INTO table1 VALUES(2, 20, "src2")

CREATE TRIGGER trg_audit_deleted
BEFORE DELETE ON table1
REFERENCING OLD TABLE AS deleted
DO INSERT INTO audit
   SELECT id, qty, note FROM deleted

DELETE FROM table1
WHERE id = 1

<q>
show table1;
show audit;
</q>
